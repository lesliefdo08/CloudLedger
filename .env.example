DATABASE_URL="postgresql://db_user:db_password@your-rds-endpoint:5432/cloudledger?schema=public"

STORAGE_PROVIDER="aws"

AWS_REGION="ap-south-1"
AWS_S3_BUCKET="your-private-bucket"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"

# Optional. Used only when STORAGE_PROVIDER is not "aws".
# Generate a random string locally, for example:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LOCAL_STORAGE_SECRET="replace-with-random-secret"

ADMIN_EMAIL="admin@cloudledger.com"
ADMIN_PASSWORD="admin123"
